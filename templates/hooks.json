{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/tl-hook.sh hook-session-start",
            "statusMessage": "Connecting to Telegram..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/hooks/tl-hook.sh hook-stop-and-wait",
            "timeout": 7200
          }
        ]
      }
    ]
  }
}
