{
  "name": "tl-codex-bridge",
  "version": "0.1.0",
  "description": "Codex ↔ Telegram Bridge",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/daemon.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "start": "node dist/daemon.js",
    "tl": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "bin": {
    "tl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "PROMPTS.md",
    "CODEX_SETUP.md",
    "skills/tl-setup/SKILL.md"
  ],
  "dependencies": {
    "@hono/node-server": "^1.8.0",
    "grammy": "^1.42.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
